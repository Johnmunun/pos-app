APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSockets) – le frontend a besoin des VITE_REVERB_* (mêmes valeurs que REVERB_*)
# Démarrer le serveur : php artisan reverb:start (ou composer dev pour tout lancer)
# En production : si Reverb n'est pas déployé ou le proxy ne gère pas les WebSockets, mettre VITE_REVERB_ENABLED=false
# pour éviter l'erreur "WebSocket connection to 'wss://...' failed" dans la console.
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=*
VITE_REVERB_APP_KEY=local
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
# VITE_REVERB_ENABLED=false

# Firebase Cloud Messaging (FCM) – notifications web
FCM_ENABLED=false
FCM_PROJECT_ID=
FCM_VAPID_PUBLIC_KEY=

# Config Web Firebase (public)
FCM_WEB_API_KEY=
FCM_WEB_AUTH_DOMAIN=
FCM_WEB_PROJECT_ID=
FCM_WEB_STORAGE_BUCKET=
FCM_WEB_MESSAGING_SENDER_ID=
FCM_WEB_APP_ID=

# Service account (HTTP v1)
# Option 1: JSON content (escaped) in env
FCM_SERVICE_ACCOUNT_JSON=
# Option 2: file path on server
FCM_SERVICE_ACCOUNT_PATH=./firebase/serviceAccountKey.json

FCM_DEFAULT_ICON_URL=/icons/icons.jpeg
FCM_DEFAULT_CLICK_URL=/dashboard

# Vite (frontend)
VITE_FCM_ENABLED=false
VITE_FCM_VAPID_PUBLIC_KEY=
VITE_FCM_WEB_API_KEY=
VITE_FCM_WEB_AUTH_DOMAIN=
VITE_FCM_WEB_PROJECT_ID=
VITE_FCM_WEB_STORAGE_BUCKET=
VITE_FCM_WEB_MESSAGING_SENDER_ID=
VITE_FCM_WEB_APP_ID=

# OpenAI (optionnel) – transcription vocale et synthèse (assistants Pharmacy / Commerce / Hardware)
# Créer une clé sur https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# E-commerce : domaine de base pour les boutiques (sous-domaines). En production, mettre votre domaine (ex: omnisolution.shop).
# Les clients accèdent à la boutique via {sous-domaine}.{ECOMmerce_BASE_DOMAIN}
ECOMmerce_BASE_DOMAIN=omnisolution.shop

# FusionPay / Money Fusion
FUSIONPAY_ENABLED=false
FUSIONPAY_API_LINK=
FUSIONPAY_BASE_URL=https://api.moneyfusion.net
FUSIONPAY_VERIFY_BASE_URL=https://www.pay.moneyfusion.net
FUSIONPAY_API_KEY=
FUSIONPAY_WEBHOOK_SECRET=
FUSIONPAY_TIMEOUT=20
FUSIONPAY_PAYIN_CURRENCY=CDF
FUSIONPAY_MINIMUM_AMOUNT=200
FUSIONPAY_INIT_ENDPOINT=/payin/init
FUSIONPAY_VERIFY_ENDPOINT=/paiementNotif/{token}
FUSIONPAY_CALLBACK_URL=
